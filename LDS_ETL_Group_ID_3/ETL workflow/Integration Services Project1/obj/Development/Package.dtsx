    <DTS:Executable
      DTS:refId="Package\Compute total sales by CPU series"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Attività Esegui SQL"
      DTS:DTSID="{C505837D-6485-482D-B1C2-5AA9005BB8A6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Compute total sales by CPU series"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D4EB8CAE-EB84-4302-971D-33501F4756D2}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="CREATE OR ALTER VIEW CPU_Sales_By_Series AS&#xA;SELECT &#xA;    Cpu.cpu_series AS cpu_series,&#xA;    SUM(Computer_sales.total_sales_USD) AS total_sales_by_series_USD&#xA;FROM &#xA;    Computer_sales, Cpu&#xA;WHERE &#xA;    Computer_sales.cpu_id = Cpu.cpu_id&#xA;GROUP BY &#xA;    Cpu.cpu_series;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Computer sales Time Geography join"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Attività Esegui SQL"
      DTS:DTSID="{13AAC56A-DA06-44F9-9E49-AD2D38181CC2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Computer sales Time Geography join"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D4EB8CAE-EB84-4302-971D-33501F4756D2}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="CREATE OR ALTER VIEW Computer_Sales_Time_Geography_Cpu_joined AS&#xA;SELECT &#xA;    Computer_sales.*,&#xA;    Time.date,&#xA;    Time.month,&#xA;    Time.year,&#xA;    Time.week,&#xA;    Time.quarter,&#xA;    Time.day_of_month,&#xA;    Time.day_of_week,&#xA;    Time.month_of_year,&#xA;    Time.month_name,&#xA;    Geography.country,&#xA;    Geography.region,&#xA;    Geography.continent,&#xA;    Geography.currency,&#xA;    Cpu.cpu_brand,&#xA;    Cpu.cpu_series,&#xA;    Cpu.cpu_name,&#xA;    Cpu.cpu_n_cores,&#xA;    Cpu.cpu_socket&#xA;FROM &#xA;    Computer_sales, Time, Geography, Cpu&#xA;WHERE&#xA;   Computer_sales.cpu_id = Cpu.cpu_id AND Computer_sales.time_id = Time.time_id AND Computer_sales.geo_id = Geography.geo_id;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Computers with 1st ranked CPUs"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Attività Esegui SQL"
      DTS:DTSID="{890A7464-56B7-4E91-8DE4-842D7F552851}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Computers with 1st ranked CPUs"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D4EB8CAE-EB84-4302-971D-33501F4756D2}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="CREATE OR ALTER VIEW Computers_with_1st_ranked_CPUs_by_sales_by_region_and_year AS&#xA;SELECT&#xA;    Computer_Sales_Time_Geography_Cpu_joined.*,&#xA;    CPU_Ranked_by_sales_by_region_and_year.total_sales_by_CPU&#xA;FROM &#xA;    Computer_Sales_Time_Geography_Cpu_joined,&#xA;    CPU_Ranked_by_sales_by_region_and_year&#xA;WHERE&#xA;    CPU_Ranked_by_sales_by_region_and_year.Rank = 1 AND&#xA;    Computer_Sales_Time_Geography_Cpu_joined.region = CPU_Ranked_by_sales_by_region_and_year.region AND&#xA;    Computer_Sales_Time_Geography_Cpu_joined.year = CPU_Ranked_by_sales_by_region_and_year.year AND&#xA;    Computer_Sales_Time_Geography_Cpu_joined.cpu_id = CPU_Ranked_by_sales_by_region_and_year.cpu_id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Rank CPUs by sales"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Attività Esegui SQL"
      DTS:DTSID="{F709FA23-7FEE-4526-99AF-83A1A8A77946}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Rank CPUs by sales"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D4EB8CAE-EB84-4302-971D-33501F4756D2}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="CREATE OR ALTER VIEW CPU_Ranked_by_sales_by_region_and_year  AS&#xA;SELECT &#xA;    Geography.region AS region,&#xA;    Time.year AS year,&#xA;    Computer_sales.cpu_id AS cpu_id,&#xA;    SUM(Computer_sales.total_sales_USD) AS total_sales_by_CPU,&#xA;    SUM(Computer_sales.cpu_sales_USD) AS total_CPU_sales_by_CPU,&#xA;    ROW_NUMBER() OVER (PARTITION BY Time.year, Geography.region ORDER BY SUM(Computer_sales.cpu_sales_USD) DESC) AS Rank&#xA;FROM &#xA;    Computer_sales, Time, Geography&#xA;WHERE &#xA;    Computer_sales.time_id = Time.time_id AND Computer_sales.geo_id = Geography.geo_id&#xA;GROUP BY    &#xA;    Geography.region,&#xA;    Time.year,&#xA;    Computer_sales.cpu_id;    " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
